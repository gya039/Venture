rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ────────────────────────────────────────────────────
    // Only the owner can read/write their own profile
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Trips ────────────────────────────────────────────────────
    // Users can only see and modify their own trips
    match /trips/{tripId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
    }

    // ── Destinations ─────────────────────────────────────────────
    match /destinations/{destId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
    }

    // ── City Spots (cache) ───────────────────────────────────────
    // Any authenticated user can read/write cached spots
    // (written by client SDK after /api/research returns spots)
    match /citySpots/{city}/spots/{spotId} {
      allow read, write: if request.auth != null;
    }

    // ── Day Plans ────────────────────────────────────────────────
    match /dayPlans/{planId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
    }

    // ── Day Plan Spots ───────────────────────────────────────────
    match /dayPlanSpots/{id} {
      allow read, write: if request.auth != null;
      // TODO: tighten by checking parent dayPlan ownership
    }

    // ── City Passes (curated, read-only for clients) ─────────────
    match /cityPasses/{city} {
      allow read: if request.auth != null;
      allow write: if false; // seeded manually via admin/console
    }
  }
}
